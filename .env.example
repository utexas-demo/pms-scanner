# Copy this file to .env and fill in the values.
# Source of truth: specs/004-multi-env-uploads/contracts/config-schema.md
# NEVER commit a filled-in copy — real tokens must stay out of git.

# ---------------------------------------------------------------------------
# Machine identity (required)
# ---------------------------------------------------------------------------
# This host's self-declared name. Must match ^[a-z0-9][a-z0-9_-]{0,30}$ and
# must NOT be a reserved name (in-progress, processed, ., ..). Used to name
# this machine's in-progress/<name>/ subfolder under every environment and to
# tag logs / dashboard records. The system refuses to start if missing/blank.
MACHINE_IDENTITY=macmini

# ---------------------------------------------------------------------------
# NTP (required unless explicitly disabled for local dev)
# ---------------------------------------------------------------------------
NTP__SOURCE=pool.ntp.org
NTP__CHECK_INTERVAL_SECONDS=3600
NTP__MAX_DRIFT_SECONDS=1.0
# Path to the out-of-band privileged clock-correction helper. Leave blank to
# run in verify-only mode (no correction attempted).
NTP__CORRECT_CLOCK_COMMAND=/usr/local/libexec/pms-scanner-correct-clock
# Setting STARTUP_REQUIRED=false is for local dev only and emits a WARNING.
NTP__STARTUP_REQUIRED=true
NTP__STARTUP_TIMEOUT_SECONDS=30

# ---------------------------------------------------------------------------
# Environments — comma-separated list of enabled env names
# Valid names: production, staging
# ---------------------------------------------------------------------------
ENVIRONMENTS=production,staging

# Production env block ------------------------------------------------------
ENV_PRODUCTION__ENABLED=true
ENV_PRODUCTION__WATCH_DIR=/Volumes/aria/ARIAscans-prod
ENV_PRODUCTION__BACKEND_BASE_URL=https://adg.mpsinc.io
ENV_PRODUCTION__API_TOKEN=your-production-token-here
# Optional UUID linking every uploaded page to a requisition. Leave blank for none.
ENV_PRODUCTION__REQUISITION_ID=
# Second-within-the-minute this env polls on this machine (0-59).
# Defaults: macmini production :00 / staging :15 ; nuc production :30 / staging :45
ENV_PRODUCTION__SCHEDULE_OFFSET_SECONDS=0

# Staging env block ---------------------------------------------------------
ENV_STAGING__ENABLED=true
ENV_STAGING__WATCH_DIR=/Volumes/aria/ARIAscans-staging
ENV_STAGING__BACKEND_BASE_URL=https://dev.adg.mpsinc.io
ENV_STAGING__API_TOKEN=your-staging-token-here
ENV_STAGING__REQUISITION_ID=
ENV_STAGING__SCHEDULE_OFFSET_SECONDS=15

# ---------------------------------------------------------------------------
# Shared settings (carried over from 003)
# ---------------------------------------------------------------------------
DASHBOARD_PORT=8080
FILE_SETTLE_SECONDS=10
UPLOAD_TIMEOUT_SECONDS=30
UPLOAD_MAX_RETRIES=3
UPLOAD_RETRY_MAX_WAIT_SECONDS=10

# Log verbosity: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
