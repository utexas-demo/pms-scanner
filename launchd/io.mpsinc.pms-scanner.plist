<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>

  <!-- Service identity -->
  <key>Label</key>
  <string>io.mpsinc.pms-scanner</string>

  <!-- Restart on exit or crash (macOS Deployment Standard, Constitution v3.0.0) -->
  <key>KeepAlive</key>
  <true/>

  <!--
    Defer startup until BOTH environment watch shares are mounted
    (004 — dual-environment routing). Adjust the paths to match the
    ENV_*__WATCH_DIR values in your .env. List every distinct mount
    point any configured watch_dir lives under.
  -->
  <key>WaitForPaths</key>
  <array>
    <string>/Volumes/aria/ARIAscans-prod</string>
    <string>/Volumes/aria/ARIAscans-staging</string>
  </array>

  <!--
    Command to run.
    Replace /Users/YOUR_USERNAME with your actual home directory.
    The Python interpreter is taken from the project's virtual environment.
  -->
  <key>ProgramArguments</key>
  <array>
    <string>/Users/YOUR_USERNAME/Projects/utexas/pms-scanner/.venv/bin/python</string>
    <string>-m</string>
    <string>scanner</string>
  </array>

  <!-- Working directory (repo root — so a local .env is found automatically) -->
  <key>WorkingDirectory</key>
  <string>/Users/YOUR_USERNAME/Projects/utexas/pms-scanner</string>

  <!-- Log files -->
  <key>StandardOutPath</key>
  <string>/tmp/pms-scanner.log</string>
  <key>StandardErrorPath</key>
  <string>/tmp/pms-scanner.error.log</string>

  <!--
    Environment variables injected at launch.

    SECRETS ARE DELIBERATELY ABSENT. The launchd XML is world-readable, so
    ENV_PRODUCTION__API_TOKEN / ENV_STAGING__API_TOKEN MUST live only in the
    .env file at WorkingDirectory (or ~/.config/pms-scanner/.env). The
    non-secret routing keys below are listed for clarity; values in .env
    take precedence and may override these.
  -->
  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key>
    <string>/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>

    <key>MACHINE_IDENTITY</key>
    <string>macmini</string>

    <key>ENVIRONMENTS</key>
    <string>production,staging</string>

    <key>ENV_PRODUCTION__WATCH_DIR</key>
    <string>/Volumes/aria/ARIAscans-prod</string>
    <key>ENV_PRODUCTION__BACKEND_BASE_URL</key>
    <string>https://adg.mpsinc.io</string>
    <key>ENV_PRODUCTION__SCHEDULE_OFFSET_SECONDS</key>
    <string>0</string>

    <key>ENV_STAGING__WATCH_DIR</key>
    <string>/Volumes/aria/ARIAscans-staging</string>
    <key>ENV_STAGING__BACKEND_BASE_URL</key>
    <string>https://dev.adg.mpsinc.io</string>
    <key>ENV_STAGING__SCHEDULE_OFFSET_SECONDS</key>
    <string>15</string>

    <key>NTP__SOURCE</key>
    <string>pool.ntp.org</string>
    <key>NTP__MAX_DRIFT_SECONDS</key>
    <string>1.0</string>
    <key>NTP__CHECK_INTERVAL_SECONDS</key>
    <string>3600</string>
    <key>NTP__CORRECT_CLOCK_COMMAND</key>
    <string>/usr/local/libexec/pms-scanner-correct-clock</string>
    <key>NTP__STARTUP_REQUIRED</key>
    <string>true</string>
  </dict>

  <!-- Run on load (after the WaitForPaths condition is satisfied) -->
  <key>RunAtLoad</key>
  <true/>

  <!--
    Throttle restarts — wait at least 10 s before restarting after a crash.
    This prevents a tight restart loop if a share is unmounted unexpectedly.
  -->
  <key>ThrottleInterval</key>
  <integer>10</integer>

</dict>
</plist>
