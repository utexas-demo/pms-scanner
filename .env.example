# Copy this file to .env and fill in the values.

# Absolute path to the folder containing scanned PDFs (the ARIA SMB share).
# For macOS: mount the ARIA share and point here.
# For Docker: this is the container-side path mapped via docker-compose.yml volumes.
WATCH_DIR=/Volumes/aria/ARIAscans

# Seconds to wait after a file appears before processing it (lets writes settle).
# Default: 10.0  — increase if scanner produces incomplete PDFs initially.
FILE_SETTLE_SECONDS=10

# How often (seconds) the cron batch runner fires to scan for new PDFs.
CRON_INTERVAL_SECONDS=60

# Port the live progress dashboard listens on.
DASHBOARD_PORT=8080

# Base URL of the pms-backend (no trailing slash).
# Upload endpoint: POST {BACKEND_BASE_URL}/api/scanned-images/upload
BACKEND_BASE_URL=https://api.example.com

# JWT Bearer token issued by the backend.
API_TOKEN=your-jwt-token-here

# Optional: link every uploaded page to an existing requisition UUID.
# Leave blank to upload without a requisition association.
# REQUISITION_ID=00000000-0000-0000-0000-000000000000

# HTTP timeout for upload requests (seconds).
UPLOAD_TIMEOUT_SECONDS=30

# Maximum number of upload attempts per page (initial attempt + retries).
# Transient 5xx errors are retried with exponential back-off.
UPLOAD_MAX_RETRIES=3

# Maximum wait between retries in seconds (back-off ceiling).
UPLOAD_RETRY_MAX_WAIT_SECONDS=10

# Log verbosity: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
