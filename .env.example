# Copy this file to .env and fill in the values.

# Absolute path to the folder that will be watched for incoming images
WATCH_DIR=/data/incoming

# Recurse into sub-folders (true/false)
WATCH_RECURSIVE=true

# Seconds to wait after a file appears before uploading (lets writes settle)
FILE_SETTLE_SECONDS=0.5

# Base URL of the pms-backend (no trailing slash)
# Upload endpoint: POST {BACKEND_BASE_URL}/api/scanned-images/upload
BACKEND_BASE_URL=https://api.example.com

# JWT Bearer token issued by the backend
API_TOKEN=your-jwt-token-here

# Optional: link every uploaded image to an existing requisition UUID
# Leave blank to upload images without a requisition association
# REQUISITION_ID=00000000-0000-0000-0000-000000000000

# HTTP timeout for upload requests (seconds)
UPLOAD_TIMEOUT_SECONDS=30

# Log verbosity: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
